			OutputDirectory="Debug_VS2008"
			IntermediateDirectory="Debug_VS2008"
			ConfigurationType="1"
			DeleteExtensionsOnClean="*.obj;*.d;*.map;*.lst;*.pch;$(TargetPath);$(TargetDir)$(TargetName).self"
			>
			<Tool
				Name="VCPreBuildEventTool"
			/>
