				Name="VCPostBuildEventTool"
				Description="Fake Signing ELF &quot;$(TargetDir)$(TargetName).self&quot;"
				CommandLine="$(SCE_PS3_ROOT)\host-win32\bin\make_fself &quot;$(TargetPath)&quot; &quot;$(TargetDir)$(TargetName).self&quot;"
			/>
