      Πάτα{*CONTROLLER_VK_B*} τώρα για έξοδο από το περιβάλλον εργασίας κατασκευών.
    </value>
	</data>	

	<data name="IDS_TUTORIAL_TASK_CRAFT_CREATE_FURNACE">
