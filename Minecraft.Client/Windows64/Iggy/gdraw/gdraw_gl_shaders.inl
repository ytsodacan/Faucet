   "         #ifdef FLASH_10\n"
   "            gl_Position = wpos.x * x3d + wpos.y * y3d + w3d;  // z is ignored!\n"
   "            gl_Position.w = gl_Position.z;\n"
   "            gl_Position.z = wpos.z * gl_Position.w;\n"
   "         #endif\n"
   "        }   \n";
