   "            tex_coord.z = in_attr.x / 32.0;\n"
   "        #endif\n"
   "        \n"
   "            // view/projection transform\n"
   "            gl_Position = vec4(wpos.xy * viewproj.xy + viewproj.zw, wpos.zw);\n"
